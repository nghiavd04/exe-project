# Caddyfile - Reverse Proxy Configuration
# Sử dụng domain thực

# Cấu hình cũ cho chạy HTTP (Port 80) hoặc localhost:
# {
#     auto_https off
# }
# :80 

dopaless.cloud {
    # Reverse proxy cho API backend (JavaSpring)
    # Tất cả requests đến /api/*, /oauth2/*, /login/oauth2/* sẽ được chuyển đến backend
    handle /api/* {
        reverse_proxy backend:8080
    }

    handle /oauth2/authorize/* {
        reverse_proxy backend:8080
    }

    handle /login/oauth2/* {
        reverse_proxy backend:8080
    }

    # Reverse proxy cho frontend (React)
    # Tất cả requests còn lại sẽ được chuyển đến frontend
    handle {
        reverse_proxy frontend:80
    }

    # Logging
    log {
        output stdout
        format console
    }
}
